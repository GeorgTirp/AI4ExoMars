{
  "method": "bayes",
  "metric": {
    "name": "val/loss",
    "goal": "minimize"
  },
  "parameters": {
    "optimization.learning_rate": {
      "distribution": "log_uniform_values",
      "min": 1e-05,
      "max": 0.001
    },
    "student_model.local_base_channels": {
      "values": [24, 32, 40]
    },
    "student_model.context_dim": {
      "values": [128, 192, 256]
    },
    "distillation.feature_weights": {
      "values": [
        [1.0, 1.0, 1.0],
        [0.5, 1.0, 1.5],
        [0.25, 0.75, 2.0]
      ]
    }
  }
}
