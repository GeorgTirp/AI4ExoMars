{
  "method": "bayes",
  "metric": {
    "name": "val/loss",
    "goal": "minimize"
  },
  "parameters": {
    "optimization.learning_rate": {
      "distribution": "log_uniform_values",
      "min": 1e-05,
      "max": 0.001
    },
    "optimization.weight_decay": {
      "distribution": "log_uniform_values",
      "min": 1e-05,
      "max": 0.05
    },
    "model.mask_ratio": {
      "values": [0.4, 0.5, 0.6, 0.7]
    },
    "model.local_base_channels": {
      "values": [32, 48, 64]
    },
    "data.batch_size": {
      "values": [4, 8, 16]
    }
  }
}
